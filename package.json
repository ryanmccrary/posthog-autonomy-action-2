{
  "name": "posthog-pr-autonomy-bot",
  "version": "0.2.0",
  "private": true,
  "description": "Proactive PostHog instrumentation reviewer for GitHub PRs (analytics, logs, error tracking, LLM analytics, feature flags).",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt && rm -rf dist/prompts && cp -R src/prompts dist/prompts",
    "start": "node --enable-source-maps dist/index.js",
    "dev": "tsx watch src/index.ts",
    "local": "tsx scripts/local-run.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@anthropic-ai/sdk": "^0.40.0",
    "@octokit/rest": "^21.0.2",
    "dotenv": "^16.4.5",
    "parse-diff": "^0.11.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@vercel/ncc": "^0.38.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
